#!/usr/bin/env php
<?php

// Installed as a dependency: vendor/uxcode-fr/font-optimizer/bin/ → vendor/autoload.php
// Standalone (development):  bin/ → vendor/autoload.php
$autoload = file_exists(__DIR__ . '/../../autoload.php')
    ? __DIR__ . '/../../autoload.php'
    : __DIR__ . '/../vendor/autoload.php';

if (!file_exists($autoload)) {
    fwrite(STDERR, "Composer autoloader not found. Run 'composer install'.\n");
    exit(1);
}

require_once $autoload;

use FontOptimizer\Command\OptimizeCommand;
use Symfony\Component\Console\Application;

$app = new Application('Font Optimizer', '1.0.0');
$app->add(new OptimizeCommand());
$app->setDefaultCommand('optimize');
$app->run();